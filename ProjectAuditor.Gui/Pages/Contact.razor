@page "/contact"

<PageTitle>Kontakt</PageTitle>

<div class="max-w-7xl mt-8 pb-12">
    <!-- Header -->
    <div class="mb-10 px-4 sm:px-0 text-left">
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Kontakt</h1>
        <p class="text-gray-500 mt-2">Haben Sie Fragen oder Feedback? So erreichen Sie mich.</p>
    </div>

    <!-- Contact Card -->
    <div class="max-w-2xl bg-white shadow-lg rounded-2xl border border-gray-100 overflow-hidden mx-4 sm:mx-0">
        <div class="p-6 md:p-8">
            <div class="flex items-center gap-3 mb-8">
                <div class="p-2 bg-blue-50 rounded-lg text-blue-600">
                    <span class="oi oi-person text-xl"></span>
                </div>
                <h2 class="text-xl font-bold text-gray-900">Entwickler</h2>
            </div>

            <div class="space-y-6">
                <div class="flex items-start gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100 hover:border-blue-200 transition-colors">
                    <div class="p-2 bg-white rounded-lg shadow-sm text-gray-400">
                        <span class="oi oi-envelope-closed"></span>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-blue-600 uppercase tracking-wider mb-1">E-Mail</p>
                        <a href="mailto:ptolstoi@gmail.com" class="text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors">
                            ptolstoi@gmail.com
                        </a>
                    </div>
                </div>

                <div class="flex items-start gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100 hover:border-blue-200 transition-colors">
                    <div class="p-2 bg-white rounded-lg shadow-sm text-gray-400">
                        <span class="oi oi-external-link"></span>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-blue-600 uppercase tracking-wider mb-1">GitHub</p>
                        <a href="https://github.com/ptolstoi-dev" target="_blank" class="text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors">
                            github.com/ptolstoi-dev
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
