@page "/"
@using ProjectAuditor.Core.Services
@using ProjectAuditor.Core.Models
@inject DotNetCliService CliService
@inject AuditorEngine Engine

<PageTitle>Project Auditor</PageTitle>

<div class="container-lg mt-4">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h1 class="display-4 text-primary fw-bold">🚀 Project Auditor</h1>
            <p class="lead">Scanne und aktualisiere NuGet-Pakete in deinen .NET Projekten.</p>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title">Projektverzeichnis</h5>
            <div class="input-group mb-3">
                <input type="text" class="form-control form-control-lg" @bind="targetPath" placeholder="C:\Pfad\zur\Solution" />
                <button class="btn btn-primary btn-lg" @onclick="ScanDirectory" disabled="@isScanning">
                    @if (isScanning)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span> Scanne...</span>
                    }
                    else
                    {
                        <span>🔍 Scannen</span>
                    }
                </button>
            </div>
            
            @if (errorMessage != null)
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
        </div>
    </div>

    @if (upgradablePackages != null)
    {
        @if (!upgradablePackages.Any())
        {
            <div class="alert alert-success d-flex align-items-center" role="alert">
                <span>✅ Keine zu aktualisierenden oder anfälligen Pakete gefunden. Dein Projekt ist aktuell!</span>
            </div>
        }
        else
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">📦 Gefundene Pakete (@GetTotalRows())</h5>
                    <button class="btn btn-warning btn-sm fw-bold" @onclick="ApplyUpgrades" disabled="@isFixing">
                        @if (isFixing)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Führe Updates aus...</span>
                        }
                        else
                        {
                            <span>⚡ Ausgewählte Updates anwenden</span>
                        }
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0" style="font-size: 0.95rem;">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" style="width: 20%;">Projekt</th>
                                    <th scope="col" style="width: 25%;">
                                        <div class="form-check d-inline-block me-2">
                                            <input class="form-check-input" type="checkbox" id="selectAll" checked="@AreAllSelected()" @onchange="ToggleSelectAll">
                                            Paketname
                                        </div>
                                    </th>
                                    <th scope="col" style="width: 15%;">Aktuelle Version</th>
                                    <th scope="col" style="width: 20%;">Auditergebnis</th>
                                    <th scope="col" style="width: 20%;">Zielversion</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pkg in upgradablePackages)
                                {
                                    @foreach (var proj in pkg.Projects)
                                    {
                                        <tr>
                                            <td class="align-middle">
                                                <span title="@proj.ProjectPath">@proj.ProjectName</span>
                                            </td>
                                            <td class="align-middle">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="@($"{pkg.PackageId}_{proj.ProjectName}")" @bind="proj.IsSelectedForUpgrade">
                                                    <label class="form-check-label" for="@($"{pkg.PackageId}_{proj.ProjectName}")">
                                                        @pkg.PackageId
                                                    </label>
                                                </div>
                                            </td>
                                            <td class="align-middle">
                                                <span class="badge p-2 bg-secondary text-white">@pkg.CurrentVersion</span>
                                            </td>
                                            <td class="align-middle">
                                                @if (pkg.Vulnerabilities.Any())
                                                {
                                                    @foreach (var vuln in pkg.Vulnerabilities)
                                                    {
                                                        <span class="badge p-2 @GetSeverityClass(vuln.Severity) me-1">@vuln.Severity</span>
                                                    }
                                                }
                                                else if (pkg.Reasons.Contains("Outdated"))
                                                {
                                                    <span class="badge p-2 bg-info text-dark">Outdated</span>
                                                }
                                                else if (pkg.Reasons.Contains("Deprecated"))
                                                {
                                                    <span class="badge p-2 bg-warning text-dark">Deprecated</span>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                <select class="form-select form-select-sm" @bind="pkg.SelectedVersion">
                                                    @if (!pkg.AvailableVersions.Contains(pkg.SelectedVersion) && !string.IsNullOrEmpty(pkg.SelectedVersion))
                                                    {
                                                        <option value="@pkg.SelectedVersion">@pkg.SelectedVersion</option>
                                                    }
                                                    @foreach (var ver in pkg.AvailableVersions)
                                                    {
                                                        <option value="@ver">@ver</option>
                                                    }
                                                    <option value="@pkg.CurrentVersion">@pkg.CurrentVersion (Ignorieren)</option>
                                                </select>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
    
    @if (fixComplete)
    {
         <div class="alert alert-info d-flex align-items-center" role="alert">
            <span>ℹ️ Update-Vorgang abgeschlossen! (Log `nugetAudit_yyMMdd.json` wurde erzeugt)</span>
        </div>
    }
</div>

@code {
    private string targetPath = @"c:\PAT\projekte\_portfolio\github\ProjectAuditor";
    private bool isScanning;
    private bool isFixing;
    private bool fixComplete;
    private string? errorMessage;
    private List<PackageUpgradeModel>? upgradablePackages;

    private async Task ScanDirectory()
    {
        try
        {
            isScanning = true;
            errorMessage = null;
            fixComplete = false;
            upgradablePackages = null;
            StateHasChanged();

            upgradablePackages = await Task.Run(() => Engine.GetUpgradablePackagesAsync(targetPath));
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler beim Scannen: {ex.Message}";
        }
        finally
        {
            isScanning = false;
            StateHasChanged();
        }
    }

    private async Task ApplyUpgrades()
    {
        try
        {
            if (upgradablePackages == null || !upgradablePackages.Any()) return;

            isFixing = true;
            errorMessage = null;
            fixComplete = false;
            StateHasChanged();

            await Task.Run(() => Engine.ApplyUpgradesAsync(targetPath, upgradablePackages));

            fixComplete = true;

            // Rescan after fix
            upgradablePackages = await Task.Run(() => Engine.GetUpgradablePackagesAsync(targetPath));
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler bei der Reparatur: {ex.Message}";
        }
        finally
        {
            isFixing = false;
            StateHasChanged();
        }
    }

    private int GetTotalRows()
    {
        if (upgradablePackages == null) return 0;
        return upgradablePackages.Sum(pkg => pkg.Projects.Count);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (upgradablePackages == null) return;

        bool isChecked = (bool)(e.Value ?? false);
        foreach (var pkg in upgradablePackages)
        {
            foreach (var proj in pkg.Projects)
            {
                proj.IsSelectedForUpgrade = isChecked;
            }
        }
    }

    private bool AreAllSelected()
    {
        if (upgradablePackages == null || !upgradablePackages.Any())
            return false;

        return upgradablePackages
            .SelectMany(pkg => pkg.Projects)
            .All(proj => proj.IsSelectedForUpgrade);
    }

    private string GetSeverityClass(string severity)
    {
        return severity.ToLowerInvariant() switch
        {
            "critical" => "bg-danger text-white",      // Rot
            "high" => "severity-high",                 // Orange mit besserem Kontrast
            "moderate" => "severity-moderate",         // Gelb mit besserem Kontrast
            "low" => "bg-info text-white",             // Blau
            _ => "bg-secondary text-white"
        };
    }
}