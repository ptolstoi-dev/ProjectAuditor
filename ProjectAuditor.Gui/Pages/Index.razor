@page "/"
@using ProjectAuditor.Core.Services
@using ProjectAuditor.Core.Models
@using System.Diagnostics
@inject DotNetCliService CliService
@inject AuditorEngine Engine
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@inject ILocalizationService LocalizationService
@inject ISettingsService SettingsService

<PageTitle>Project Auditor</PageTitle>

<div class="max-w-7xl mt-8 pb-12">
    <!-- Header -->
    <div class="mb-10 px-4 sm:px-0 text-left">
        <h1 class="text-5xl font-extrabold text-blue-600 mb-4 tracking-tight">
            🚀 @L("Index.Title")
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl">
            @L("Index.Description")
        </p>
    </div>

    <!-- Main Config Card -->
    <div class="bg-white shadow-lg rounded-2xl border border-gray-100 overflow-hidden mb-8 mx-4 sm:mx-0">
        <div class="p-6 md:p-8 text-left">
            <div class="flex items-center gap-3 mb-6">
                <div class="p-2 bg-blue-50 rounded-lg text-blue-600">
                    <span class="oi oi-folder text-xl"></span>
                </div>
                <h2 class="text-xl font-bold text-gray-900">@L("Index.ProjectDirectoryLabel")</h2>
            </div>
            
            <div class="flex flex-col gap-4 mb-4">
                <div class="w-full">
                    <input type="text" 
                           class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-lg bg-gray-50" 
                           @bind="targetPath" 
                           placeholder="@L("Index.Placeholder")" />
                </div>
                <div class="flex flex-wrap gap-3">
                    <button class="px-6 py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-400 transition-all flex items-center whitespace-nowrap active:scale-95" 
                            @onclick="OpenFolderInExplorer" 
                            title="@L("Index.OpenExplorer")">
                        <span class="mr-2">📁</span>
                        <span>@L("Index.OpenExplorer")</span>
                    </button>
                    <button class="px-8 py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 shadow-md hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed transition-all flex items-center justify-center min-w-[160px] active:scale-95" 
                            @onclick="ScanDirectory" 
                            disabled="@isScanning">
                        @if (isScanning)
                        {
                            <svg class="animate-spin h-5 w-5 mr-3 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span>@L("Index.Scanning")</span>
                        }
                        else
                        {
                            <span class="oi oi-magnifying-glass mr-2"></span>
                            <span>@L("Index.ScanProject")</span>
                        }
                    </button>
                </div>
            </div>
            
            @if (errorMessage != null)
            {
                <div class="bg-red-50 border-l-4 border-red-500 p-4 mt-6 rounded-r-lg shadow-sm">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <span class="oi oi-circle-x text-red-500"></span>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-700 font-bold">@errorMessage</p>
                        </div>
                    </div>
                </div>
            }

            @if (currentProgress != null && (isScanning || isFixing))
            {
                <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 mt-8 shadow-sm">
                    <div class="flex justify-between items-center mb-4">
                        <div class="flex items-center text-left">
                            <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider mr-3 @GetProgressStageBadgeClass(currentProgress.Stage)">
                                @GetProgressStageText(currentProgress.Stage)
                            </span>
                            <span class="font-bold text-blue-900">@currentProgress.Message</span>
                        </div>
                        <span class="text-blue-700 font-mono font-bold">@currentProgress.PercentComplete%</span>
                    </div>

                    @if (currentProgress.CurrentPackage != null)
                    {
                        <div class="text-xs text-blue-800 mb-4 bg-white/50 p-3 rounded-xl border border-blue-100 flex flex-wrap gap-y-2 gap-x-6 text-left">
                            <div class="flex items-center gap-2">
                                <span class="text-blue-400">📦</span>
                                <span>@L("Progress.Package"): <code class="font-mono font-bold bg-blue-100 px-1 rounded">@currentProgress.CurrentPackage</code></span>
                            </div>
                            @if (!string.IsNullOrEmpty(currentProgress.CurrentProject))
                            {
                                <div class="flex items-center gap-2">
                                    <span class="text-blue-400">📂</span>
                                    <span>@L("Progress.Project"): <code class="font-mono font-bold bg-blue-100 px-1 rounded">@currentProgress.CurrentProject</code></span>
                                </div>
                            }
                        </div>
                    }

                    <div class="w-full bg-blue-100 rounded-full h-6 overflow-hidden shadow-inner border border-blue-200">
                        @if (currentProgress.PercentComplete >= 0)
                        {
                            <div class="bg-blue-600 h-full transition-all duration-500 ease-out relative" style="width: @(currentProgress.PercentComplete + "%")">
                                <div class="absolute inset-0 bg-white/20 animate-[shimmer_2s_infinite] skew-x-[-20deg]"></div>
                            </div>
                        }
                        else
                        {
                            <div class="bg-blue-600 h-full w-full animate-pulse relative">
                                <div class="absolute inset-0 bg-white/20 animate-[shimmer_2s_infinite] skew-x-[-20deg]"></div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    @if (upgradablePackages != null)
    {
        @if (!upgradablePackages.Any())
        {
            <div class="bg-green-50 border-l-4 border-green-500 p-6 rounded-r-2xl shadow-sm mx-4 sm:mx-0 max-w-4xl text-left">
                <div class="flex items-center">
                    <div class="flex-shrink-0 text-green-500 text-2xl">
                        <span class="oi oi-circle-check"></span>
                    </div>
                    <div class="ml-4">
                        <p class="text-lg text-green-800 font-bold">@L("Index.NoPackagesFound")</p>
                        <p class="text-green-700">@L("Index.NoUpdatesMessage")</p>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="bg-white shadow-xl rounded-2xl border border-gray-100 overflow-hidden mb-8 mx-4 sm:mx-0 text-left">
                <div class="bg-gray-50 px-6 py-4 border-b border-gray-100 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <div class="flex items-center gap-3">
                        <div class="p-2 bg-gray-200 rounded-lg text-gray-600">
                            <span class="oi oi-list text-lg"></span>
                        </div>
                        <h2 class="text-lg font-bold text-gray-900">
                            @L("Index.FoundPackages")
                            <span class="ml-2 px-2.5 py-0.5 bg-gray-200 text-gray-700 text-xs rounded-full font-mono">@GetTotalRows()</span>
                        </h2>
                    </div>

                    <button class="w-full sm:w-auto px-6 py-2.5 bg-amber-500 text-white font-bold rounded-xl hover:bg-amber-600 shadow-md hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-amber-400 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed transition-all flex items-center justify-center active:scale-95" 
                            @onclick="ApplyUpgrades" 
                            disabled="@isFixing">
                        @if (isFixing)
                        {
                            <svg class="animate-spin h-4 w-4 mr-2 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span>@L("Index.ApplyingUpdates")</span>
                        }
                        else
                        {
                            <span class="oi oi-bolt mr-2"></span>
                            <span>@L("Index.ApplyUpdatesButton")</span>
                        }
                    </button>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-100">
                        <thead class="bg-gray-50/50">
                            <tr>
                                <th scope="col" class="px-6 py-4 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest w-[20%]">@L("Index.TableHeaderProject")</th>
                                <th scope="col" class="px-6 py-4 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest w-[25%]">
                                    <div class="flex items-center">
                                        <input type="checkbox" 
                                               id="selectAll" 
                                               class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded mr-3 cursor-pointer" 
                                               checked="@AreAllSelected()" 
                                               @onchange="ToggleSelectAll">
                                        <span>@L("Index.TableHeaderPackage")</span>
                                    </div>
                                </th>
                                <th scope="col" class="px-6 py-4 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest w-[15%]">@L("Index.TableHeaderCurrent")</th>
                                <th scope="col" class="px-6 py-4 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest w-[20%]">@L("Index.TableHeaderStatus")</th>
                                <th scope="col" class="px-6 py-4 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest w-[20%]">@L("Index.TableHeaderTargetVersion")</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-50">
                            @foreach (var group in upgradablePackages.GroupBy(p => p.GroupName ?? L("Index.OtherPackages")).OrderBy(g => g.Key == L("Index.OtherPackages") ? 1 : 0).ThenBy(g => g.Key))
                            {
                                @if (upgradablePackages.Any(p => p.GroupName != null))
                                {
                                    <tr>
                                        <td colspan="5" class="px-6 py-2 text-xs font-bold text-gray-700 uppercase tracking-widest bg-gray-100 border-y border-gray-200">
                                            @(group.Key != L("Index.OtherPackages") ? $"📦 {L("Index.GroupHeader")} " : "") @group.Key
                                        </td>
                                    </tr>
                                }
                                @foreach (var pkg in group)
                                {
                                    @foreach (var proj in pkg.Projects)
                                    {
                                        <tr class="hover:bg-blue-50/30 transition-colors group">
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <span class="truncate block max-w-[200px]" title="@proj.ProjectPath">@proj.ProjectName</span>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <div class="flex items-center">
                                                    <input type="checkbox" 
                                                           id="@($"{pkg.PackageId}_{proj.ProjectName}")" 
                                                           class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded mr-3 cursor-pointer" 
                                                           @bind="proj.IsSelectedForUpgrade">
                                                    <label class="text-sm font-bold text-gray-900 cursor-pointer group-hover:text-blue-600 transition-colors" for="@($"{pkg.PackageId}_{proj.ProjectName}")">
                                                        @pkg.PackageId
                                                    </label>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <span class="px-2 py-1 bg-gray-100 text-gray-600 text-[11px] font-mono font-bold rounded border border-gray-200">
                                                    @pkg.CurrentVersion
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <div class="flex flex-wrap gap-1">
                                                    @if (pkg.Vulnerabilities.Any())
                                                    {
                                                        @foreach (var vuln in pkg.Vulnerabilities)
                                                        {
                                                            <span class="px-2 py-0.5 rounded text-[9px] font-extrabold uppercase tracking-tighter @GetSeverityClass(vuln.Severity)">
                                                                @vuln.Severity
                                                            </span>
                                                        }
                                                    }
                                                    else if (pkg.Reasons.Contains("Outdated"))
                                                    {
                                                        <span class="px-2 py-0.5 bg-sky-100 text-sky-700 rounded text-[9px] font-extrabold uppercase tracking-tighter border border-sky-200">
                                                            @L("Index.StatusOutdated")
                                                        </span>
                                                    }
                                                    else if (pkg.Reasons.Contains("Deprecated"))
                                                    {
                                                        <span class="px-2 py-0.5 bg-amber-100 text-amber-700 rounded text-[9px] font-extrabold uppercase tracking-tighter border border-amber-200">
                                                            @L("Index.StatusDeprecated")
                                                        </span>
                                                    }
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <select class="block w-full text-xs bg-gray-50 border-gray-200 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 py-1.5 font-mono font-bold text-blue-700 cursor-pointer" @bind="pkg.SelectedVersion">
                                                    @if (!pkg.AvailableVersions.Contains(pkg.SelectedVersion) && !string.IsNullOrEmpty(pkg.SelectedVersion))
                                                    {
                                                        <option value="@pkg.SelectedVersion">@pkg.SelectedVersion</option>
                                                    }
                                                    @foreach (var ver in pkg.AvailableVersions)
                                                    {
                                                        <option value="@ver">@ver</option>
                                                    }
                                                    <option value="@pkg.CurrentVersion">@pkg.CurrentVersion (@L("Index.IgnoreOption"))</option>
                                                </select>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    
    @if (fixComplete)
    {
         <div class="@(currentProgress?.IsError == true ? "bg-amber-600 border-amber-400" : "bg-blue-600 border-blue-400") border-l-8 p-6 rounded-2xl shadow-xl mx-4 sm:mx-0 max-w-4xl animate-bounce text-left cursor-pointer hover:shadow-2xl transition-shadow" @onclick="OpenLogModal">
            <div class="flex items-center">
                <span class="mr-4 text-white text-3xl">@(currentProgress?.IsError == true ? "⚠️" : "🎉")</span>
                <div class="flex-1">
                    <p class="text-lg text-white font-bold">@currentProgress?.Message</p>
                    @if (currentProgress?.IsError != true)
                    {
                        <p class="text-blue-100 text-sm italic">@L("Index.LogGenerated").Replace("{logFile}", $"nugetAudit_{DateTime.Now:yyMMdd}.json")</p>
                        <p class="text-blue-100 text-xs mt-1 opacity-75">@L("Index.ClickToViewLogs")</p>
                    }
                    else
                    {
                        <p class="text-amber-100 text-sm italic">@L("Index.SomeUpdatesFailed")</p>
                    }
                </div>
                <span class="ml-4 text-white text-xl opacity-75">
                    <span class="oi oi-external-link"></span>
                </span>
            </div>
        </div>
    }
</div>

<!-- Audit Log Modal -->
<AuditLogModal IsVisible="@showLogModal" OnClose="@CloseLogModal" AuditLogPath="@GetAuditLogPath()" />

@code {
    private string targetPath = string.Empty;
    private bool isScanning;
    private bool isFixing;
    private bool fixComplete;
    private string? errorMessage;
    private List<PackageUpgradeModel>? upgradablePackages;
    private ProgressUpdate? currentProgress;
    private bool showLogModal = false;

    /// <summary>
    /// Hilfsmethode zum Abrufen von lokalisierten Strings.
    /// </summary>
    private string L(string key) => LocalizationService.GetString(key, key);

    /// <summary>
    /// Initialize with current working directory and load localization settings
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        // Lade die Spracheinstellung aus den Einstellungen
        var settings = await SettingsService.LoadSettingsAsync();
        LocalizationService.SetLanguage(settings.Language);

        // Setze initial path zu current working directory wenn leer
        if (string.IsNullOrEmpty(targetPath))
        {
            targetPath = Directory.GetCurrentDirectory();
        }
        await base.OnInitializedAsync();
    }

    /// <summary>
    /// Event handler for progress updates from AuditorEngine
    /// Must use InvokeAsync because event is triggered from background thread
    /// </summary>
    private void OnProgressChanged(ProgressUpdate update)
    {
        // Fire-and-forget async to avoid blocking
        _ = InvokeAsync(async () =>
        {
            currentProgress = update;
            await InvokeAsync(StateHasChanged);
        });
    }

    /// <summary>
    /// Open current folder in Windows Explorer
    /// </summary>
    private void OpenFolderInExplorer()
    {
        try
        {
            // Validate path exists
            if (string.IsNullOrEmpty(targetPath) || !Directory.Exists(targetPath))
            {
                errorMessage = LocalizationService.GetString("Errors.DirectoryNotFound", "Das eingegebene Verzeichnis existiert nicht.");
                return;
            }

            // Open the folder in Windows Explorer
            var processInfo = new ProcessStartInfo()
            {
                FileName = "explorer.exe",
                Arguments = $"/select,\"{targetPath}\"",
                UseShellExecute = true
            };
            Process.Start(processInfo);
        }
        catch (Exception ex)
        {
            var errorMsg = LocalizationService.GetString("Errors.OpenExplorerError", "Fehler beim Öffnen des Explorers: {error}")
                .Replace("{error}", ex.Message);
            errorMessage = errorMsg;
        }
    }

    /// <summary>
    /// Get the badge CSS class for a progress stage
    /// </summary>
    private string GetProgressStageBadgeClass(ProgressStage stage)
    {
        return stage switch
        {
            ProgressStage.ScanningVulnerable => "bg-red-600 text-white",
            ProgressStage.ScanningOutdated => "bg-amber-500 text-white",
            ProgressStage.ScanningDeprecated => "bg-amber-500 text-white",
            ProgressStage.FetchingVersions => "bg-blue-500 text-white",
            ProgressStage.ApplyingUpdates => "bg-blue-700 text-white",
            ProgressStage.Verifying => "bg-gray-600 text-white",
            ProgressStage.Complete => "bg-green-600 text-white",
            ProgressStage.Failed => "bg-red-600 text-white",
            _ => "bg-gray-500 text-white"
        };
    }

    /// <summary>
    /// Get human-readable text for a progress stage - localized
    /// </summary>
    private string GetProgressStageText(ProgressStage stage)
    {
        var key = stage switch
        {
            ProgressStage.ScanningVulnerable => "Progress.ScanningVulnerable",
            ProgressStage.ScanningOutdated => "Progress.ScanningOutdated",
            ProgressStage.ScanningDeprecated => "Progress.ScanningDeprecated",
            ProgressStage.FetchingVersions => "Progress.FetchingVersions",
            ProgressStage.ApplyingUpdates => "Progress.ApplyingUpdates",
            ProgressStage.Verifying => "Progress.Verifying",
            ProgressStage.Complete => "Progress.Completed",
            ProgressStage.Failed => "Progress.Failed",
            _ => "Progress.Scanning"
        };
        return LocalizationService.GetString(key, key);
    }

    private async Task ScanDirectory()
    {
        try
        {
            isScanning = true;
            errorMessage = null;
            fixComplete = false;
            upgradablePackages = null;
            currentProgress = null;
            StateHasChanged();

            // Subscribe to progress updates
            Engine.OnProgress += OnProgressChanged;

            upgradablePackages = await Task.Run(() => Engine.GetUpgradablePackagesAsync(targetPath));
        }
        catch (Exception ex)
        {
            var errorMsg = LocalizationService.GetString("Errors.ScanError", "Fehler beim Scannen: {error}")
                .Replace("{error}", ex.Message);
            errorMessage = errorMsg;
        }
        finally
        {
            // Unsubscribe from progress updates
            Engine.OnProgress -= OnProgressChanged;
            isScanning = false;
            StateHasChanged();
        }
    }

    private async Task ApplyUpgrades()
    {
        try
        {
            if (upgradablePackages == null || !upgradablePackages.Any()) return;

            isFixing = true;
            errorMessage = null;
            fixComplete = false;
            currentProgress = null;
            StateHasChanged();

            // Subscribe to progress updates
            Engine.OnProgress += OnProgressChanged;
            Engine.OnGroupFallback = OnGroupFallbackHandler;

            await Task.Run(() => Engine.ApplyUpgradesAsync(targetPath, upgradablePackages));

            fixComplete = true;
            // Note: Rescan is NOT done automatically anymore - user can click "Scannen" to refresh
        }
        catch (Exception ex)
        {
            var errorMsg = LocalizationService.GetString("Errors.FixError", "Fehler bei der Reparatur: {error}")
                .Replace("{error}", ex.Message);
            errorMessage = errorMsg;
        }
        finally
        {
            // Unsubscribe from progress updates
            Engine.OnProgress -= OnProgressChanged;
            Engine.OnGroupFallback = null;
            isFixing = false;
            StateHasChanged();
        }
    }

    private int GetTotalRows()
    {
        if (upgradablePackages == null) return 0;
        return upgradablePackages.Sum(pkg => pkg.Projects.Count);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (upgradablePackages == null) return;

        bool isChecked = (bool)(e.Value ?? false);
        foreach (var pkg in upgradablePackages)
        {
            foreach (var proj in pkg.Projects)
            {
                proj.IsSelectedForUpgrade = isChecked;
            }
        }
    }

    private bool AreAllSelected()
    {
        if (upgradablePackages == null || !upgradablePackages.Any())
            return false;

        return upgradablePackages
            .SelectMany(pkg => pkg.Projects)
            .All(proj => proj.IsSelectedForUpgrade);
    }

    private string GetSeverityClass(string severity)
    {
        return severity.ToLowerInvariant() switch
        {
            "critical" => "bg-red-700 text-white",
            "high" => "severity-high",
            "moderate" => "severity-moderate",
            "low" => "bg-sky-500 text-white",
            _ => "bg-gray-500 text-white"
        };
    }

    private async Task<bool> OnGroupFallbackHandler(string groupName, int packageCount)
    {
        bool result = false;
        // Dispatch to UI thread if we are in background thread
        await InvokeAsync(async () =>
        {
            var message = LocalizationService.GetString("Errors.GroupFallbackPrompt", 
                "Das gemeinsame Update für die Gruppe '{group}' ({count} Pakete) ist fehlgeschlagen.\nEs gab wahrscheinlich Build-Fehler.\n\nMöchtest du einen Fallback versuchen und die Pakete einzeln und nacheinander aktualisieren (dauert länger)?")
                .Replace("{group}", groupName)
                .Replace("{count}", packageCount.ToString());
            result = await JSRuntime.InvokeAsync<bool>("confirm", message);
        });
        return result;
    }

    private void OpenLogModal()
    {
        showLogModal = true;
    }

    private async Task CloseLogModal()
    {
        showLogModal = false;
        await InvokeAsync(StateHasChanged);
    }

    private string GetAuditLogPath()
    {
        var dateStr = DateTime.Now.ToString("yyMMdd");
        var logFileName = $"nugetAudit_{dateStr}.json";
        return Path.Combine(targetPath, logFileName);
    }
}
