<div class="bg-blue-50 border-l-4 border-blue-500 p-6 mt-8 rounded-r-xl shadow-sm flex items-start gap-4" role="alert">
    <div class="flex-shrink-0">
        <span class="oi oi-pencil text-blue-500 text-xl" aria-hidden="true"></span>
    </div>
    
    <div>
        <h3 class="text-blue-900 font-bold text-lg mb-1">@Title</h3>
        <p class="text-blue-800 leading-relaxed">
            Please take our 
            <a target="_blank" class="font-bold text-blue-600 hover:text-blue-800 hover:underline transition-all" href="https://go.microsoft.com/fwlink/?linkid=2137916">
                brief survey
            </a> 
            and tell us what you think. Your feedback helps us improve!
        </p>
    </div>
</div>

@code {
    // Demonstrates how a parent component can supply parameters
    [Parameter] public string Title { get; set; } = null!;
}